    return `
      <div class="section-inner">
        <div style="display:grid;grid-template-columns:repeat(${colCount},1fr);gap:32px">
          ${columns.map((col: any) => `<div>${col.content || col.html || esc(col.text || '')}</div>`).join('')}
        </div>
      </div>`;
  },
};

// Aliases: frontend uses these type names but backend renderers use different keys
sectionRenderers['blog'] = sectionRenderers['bloglist'];
sectionRenderers['gallery-masonry'] = sectionRenderers['masonry'];
sectionRenderers['text'] = sectionRenderers['textblock'];
sectionRenderers['button'] = sectionRenderers['buttonblock'];
sectionRenderers['html'] = sectionRenderers['htmlblock'];

const renderSection = (section: Section): string => {
  if (section.visible === false) return '';

  const renderer = sectionRenderers[section.type];
  const inner = renderer
    ? renderer(section.content || {}, section.styles)
    : `<div class="section-inner"><p>${esc(section.name || section.type)}</p></div>`;

  return `<section class="site-section section-${esc(section.type)}" style="${cssFromStyles(section.styles)}">${inner}</section>`;
};

/** Rewrite internal page links to relative paths that work in the static site */
const rewriteHref = (href: string, pageSlugs: Set<string>, currentSlug: string): string => {
  if (!href || href === '#' || href.startsWith('http://') || href.startsWith('https://') || href.startsWith('mailto:') || href.startsWith('tel:')) {
    return href;
  }
  const clean = href.replace(/^\/+/, '').replace(/\/+$/, '');
  // Check if this links to a known page
  if (clean === '' || clean === '/') {
    // Link to home
    const depth = currentSlug === '' ? 0 : 1;
    return depth === 0 ? './index.html' : '../index.html';
  }
  if (pageSlugs.has(clean)) {
    const depth = currentSlug === '' ? 0 : 1;
    const prefix = depth === 0 ? './' : '../';
    return `${prefix}${clean}/index.html`;
  }
  return href;
};

const renderNavbar = (navbar: Record<string, any> | undefined, pageSlugs: Set<string> = new Set(), currentSlug: string = ''): string => {
  if (!navbar) return '';
  // navbar.logo can be { text: "..." } object or a string
  const rawBrand = navbar.brand || navbar.logo || navbar.title || '';
  const brand = typeof rawBrand === 'object' && rawBrand !== null ? (rawBrand.text || rawBrand.name || '') : rawBrand;
  const links = Array.isArray(navbar.links) ? navbar.links : [];
  // Styles may be nested under navbar.styles (frontend) or directly on navbar (legacy)
  const navStyles = navbar.styles || {};
  const bgColor = navStyles.backgroundColor || navbar.backgroundColor || '#ffffff';
  const textColor = navStyles.textColor || navbar.textColor || '#1e293b';
  const linkColor = navStyles.linkColor || navbar.linkColor || textColor;
  const logoUrl = navbar.logoUrl || navStyles.logoUrl || '';
  const btnBg = navStyles.buttonBg || '#2563eb';
  const btnText = navStyles.buttonText || '#ffffff';
  const btnRadius = navStyles.buttonRadius || '8px';
  return `
    <nav class="site-nav" style="background:${bgColor};color:${textColor}">
      <div class="nav-inner">
        <div class="nav-brand">
          ${logoUrl ? `<img src="${esc(logoUrl)}" alt="${esc(brand)}" class="nav-logo"/>` : ''}
          <span>${esc(brand)}</span>
        </div>
        <div class="nav-links">
          ${links.map((l: any, i: number) => {
            const isLast = i === links.length - 1;
            const isButton = l.isButton || (isLast && links.length > 1);
            if (isButton) {
              return `<a href="${esc(rewriteHref(l.href || l.url || '#', pageSlugs, currentSlug))}" class="btn" style="background:${btnBg};color:${btnText};border-radius:${btnRadius};padding:8px 20px;font-size:.9rem">${esc(l.label || l.text)}</a>`;
            }
            return `<a href="${esc(rewriteHref(l.href || l.url || '#', pageSlugs, currentSlug))}" style="color:${linkColor}">${esc(l.label || l.text)}</a>`;
          }).join('')}
        </div>
      </div>
    </nav>`;
};

const renderFooter = (footer: Record<string, any> | undefined, pageSlugs: Set<string> = new Set(), currentSlug: string = ''): string => {
  if (!footer) return '';
  const rawBrand = footer.logo || footer.brand || '';
  const footerBrand = typeof rawBrand === 'object' && rawBrand !== null ? (rawBrand.text || rawBrand.name || '') : rawBrand;
  const text = footer.text || footer.copyright || '';
  const links = Array.isArray(footer.links) ? footer.links : [];
  const footerStyles = footer.styles || {};
  const bgColor = footerStyles.backgroundColor || footer.backgroundColor || '#1e293b';
  const textColor = footerStyles.textColor || footer.textColor || '#94a3b8';
  return `
    <footer class="site-footer" style="background:${bgColor};color:${textColor}">
      <div class="footer-inner">
        ${links.length > 0 ? `<div class="footer-links">${links.map((l: any) => `<a href="${esc(rewriteHref(l.href || l.url || '#', pageSlugs, currentSlug))}">${esc(l.label || l.text)}</a>`).join('')}</div>` : ''}
        <p>${esc(text)}</p>
      </div>
    </footer>`;
};

const BASE_CSS = `
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;line-height:1.6;color:#334155}
img{max-width:100%;height:auto;display:block}
a{text-decoration:none;color:inherit}
.site-nav{position:sticky;top:0;z-index:50;border-bottom:1px solid rgba(0,0,0,.06)}
.nav-inner{max-width:1200px;margin:0 auto;padding:12px 24px;display:flex;align-items:center;justify-content:space-between}
.nav-brand{display:flex;align-items:center;gap:10px;font-weight:700;font-size:1.15rem}
.nav-logo{height:32px;width:auto}
.nav-links{display:flex;gap:24px;font-size:.95rem}
.site-section{width:100%}
.section-inner{max-width:1200px;margin:0 auto;padding:64px 24px;text-align:center}
.hero-inner{display:flex;flex-direction:column;align-items:center;gap:24px}
.hero-inner h1{font-size:3rem;font-weight:800;line-height:1.15;max-width:800px}
.sub{font-size:1.15rem;max-width:640px;margin:0 auto;opacity:.85}
.eyebrow{font-size:.85rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;opacity:.7}
.btn-group{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:8px}
.btn{display:inline-block;padding:12px 28px;border-radius:8px;font-weight:600;font-size:.95rem;cursor:pointer;transition:opacity .2s}
.btn:hover{opacity:.85}
.hero-img{margin-top:24px;border-radius:12px;max-height:480px;object-fit:cover}
.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;text-align:left;margin-top:40px}
.card{padding:28px;border-radius:12px;box-shadow:0 1px 3px rgba(0,0,0,.08)}
.card h3{margin-bottom:8px;font-size:1.15rem}
.card-img{width:100%;height:180px;object-fit:cover;border-radius:8px;margin-bottom:16px}
.testimonial-card{text-align:left}
.quote{font-style:italic;margin-bottom:16px;font-size:1.05rem}
.testimonial-author{display:flex;align-items:center;gap:12px}
.avatar{width:48px;height:48px;border-radius:50%;object-fit:cover}
.pricing-card{text-align:center;position:relative}
.pricing-card.popular{border:2px solid #2563eb}
.popular-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#2563eb;color:#fff;padding:2px 16px;border-radius:20px;font-size:.8rem;font-weight:600}
.price{font-size:2.5rem;font-weight:800;margin:16px 0}
.pricing-card ul{list-style:none;text-align:left;margin:16px 0}
.pricing-card li{padding:6px 0;border-bottom:1px solid rgba(0,0,0,.06)}
.pricing-card li::before{content:'✓ ';color:#22c55e;font-weight:700}
.gallery-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px;margin-top:40px}
.gallery-grid img{width:100%;height:220px;object-fit:cover;border-radius:8px}
.gallery-grid figcaption{text-align:center;margin-top:6px;font-size:.9rem;color:#64748b}
.stats-grid{display:flex;justify-content:center;gap:48px;flex-wrap:wrap}
.stat{text-align:center}
.stat-value{font-size:2.5rem;font-weight:800}
.stat-label{font-size:1rem;opacity:.7;margin-top:4px}
.team-avatar{width:80px;height:80px;border-radius:50%;object-fit:cover;margin:0 auto 12px}
.team-card{text-align:center}
.faq-list{max-width:720px;margin:32px auto 0;text-align:left}
.faq-item{border-bottom:1px solid rgba(0,0,0,.08);padding:16px 0}
.faq-item summary{cursor:pointer;font-weight:600;font-size:1.05rem}
.faq-item p{margin-top:8px;color:#64748b}
.logo-grid{display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:32px;margin-top:32px}
.logo-img{height:40px;width:auto;filter:grayscale(1);opacity:.6;transition:all .2s}
.logo-img:hover{filter:none;opacity:1}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;text-align:left;margin-top:32px}
.contact-info p{margin-bottom:8px}
.contact-form{display:flex;flex-direction:column;gap:12px}
.contact-form input,.contact-form textarea{padding:12px 16px;border:1px solid #e2e8f0;border-radius:8px;font-size:.95rem}
.about-inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;text-align:left}
.about-inner.img-left{direction:rtl}
.about-inner.img-left>*{direction:ltr}
.about-img{border-radius:12px;object-fit:cover;width:100%}
.cta-inner{display:flex;flex-direction:column;align-items:center;gap:20px}
.masonry-grid{columns:3;column-gap:16px;margin-top:40px}
.masonry-item{break-inside:avoid;margin-bottom:16px}
.masonry-item img{width:100%;border-radius:8px}
.masonry-item figcaption{text-align:center;margin-top:6px;font-size:.9rem;color:#64748b}
.form-status.success{color:#22c55e}
.form-status.error{color:#ef4444}
.site-footer{margin-top:auto}
.footer-inner{max-width:1200px;margin:0 auto;padding:32px 24px;text-align:center}
.footer-links{display:flex;justify-content:center;gap:24px;margin-bottom:16px}
.footer-links a{opacity:.7;transition:opacity .2s}
.footer-links a:hover{opacity:1}
@media(max-width:768px){
  .hero-inner h1{font-size:2rem}
  .card-grid{grid-template-columns:1fr}
  .contact-grid{grid-template-columns:1fr}
  .about-inner{grid-template-columns:1fr}
  .stats-grid{gap:24px}
  .nav-links{display:none}
}
`;

const buildPageHtml = (page: PageData, siteName: string, websiteId?: string, apiBaseUrl?: string, pageSlugs: Set<string> = new Set()): string => {
  const title = page.meta?.title || page.name || siteName;
  const description = page.meta?.description || '';
  const sections = Array.isArray(page.sections) ? page.sections : [];
  const formApiUrl = apiBaseUrl || (process.env.API_BASE_URL || `http://localhost:${process.env.PORT || 5000}/api/v1`);
  const currentSlug = (page.slug || '/').replace(/^\/+/, '').replace(/\/+$/, '');

  // Build global styles CSS from the page's globalStyles
  const gs = page.globalStyles || {};
  const globalCssParts: string[] = [];
  if (gs.primaryColor) globalCssParts.push(`--color-primary:${gs.primaryColor}`);
  if (gs.secondaryColor) globalCssParts.push(`--color-secondary:${gs.secondaryColor}`);
  if (gs.accentColor) globalCssParts.push(`--color-accent:${gs.accentColor}`);
  if (gs.backgroundColor) globalCssParts.push(`--color-bg:${gs.backgroundColor};background-color:${gs.backgroundColor}`);
  if (gs.textColor) globalCssParts.push(`--color-text:${gs.textColor};color:${gs.textColor}`);
  if (gs.fontFamily) globalCssParts.push(`font-family:${gs.fontFamily}`);
  if (gs.borderRadius) globalCssParts.push(`--radius:${gs.borderRadius}`);
  const globalStyleBlock = globalCssParts.length > 0 ? `\nbody{${globalCssParts.join(';')}}` : '';
  // Import Google Font if specified
  const fontImport = gs.fontFamily && !gs.fontFamily.includes('system') && !gs.fontFamily.includes('sans-serif')
    ? `<link rel="preconnect" href="https://fonts.googleapis.com"/><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/><link href="https://fonts.googleapis.com/css2?family=${encodeURIComponent(gs.fontFamily.split(',')[0].replace(/['"]/g, '').trim())}:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>`
    : '';

  const formScript = `
<script>
document.querySelectorAll('.contact-form').forEach(function(form){
  form.addEventListener('submit',function(e){
    e.preventDefault();
    var btn=form.querySelector('button[type=submit]');
    var status=form.querySelector('.form-status');
    var data={};
    new FormData(form).forEach(function(v,k){data[k]=v});
    btn.disabled=true;btn.textContent='Sending...';
    if(status){status.style.display='none';}
    fetch('${formApiUrl}/forms/submit',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({website_id:'${websiteId || ''}',page_slug:'${esc(page.slug || '/')}',form_name:form.dataset.formName||'contact',data:data})
    }).then(function(r){
      if(!r.ok)throw new Error('Failed');
      form.reset();
      btn.textContent='Sent!';
      if(status){status.textContent='Thank you! Your message has been sent.';status.className='form-status success';status.style.display='block';}
      setTimeout(function(){btn.disabled=false;btn.textContent='Send Message';},3000);
    }).catch(function(){
      btn.disabled=false;btn.textContent='Send Message';
      if(status){status.textContent='Something went wrong. Please try again.';status.className='form-status error';status.style.display='block';}
    });
  });
});
</script>`;

  const hasContactForm = sections.some(sec => sec.type === 'contact' && sec.visible !== false);

  return `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>${esc(title)}</title>
${description ? `<meta name="description" content="${esc(description)}"/>` : ''}
<meta property="og:title" content="${esc(title)}"/>
${description ? `<meta property="og:description" content="${esc(description)}"/>` : ''}
<meta property="og:type" content="website"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="${esc(title)}"/>
${description ? `<meta name="twitter:description" content="${esc(description)}"/>` : ''}
<link rel="canonical" href="/"/>
<style>${BASE_CSS}${globalStyleBlock}</style>
${fontImport}
</head>
<body>
${renderNavbar(page.navbar, pageSlugs, currentSlug)}
<main>
${sections.map(renderSection).join('\n')}
</main>
${renderFooter(page.footer, pageSlugs, currentSlug)}
${hasContactForm ? formScript : ''}
</body>
</html>`;
};

export const generateStaticSite = (content: Record<string, any>, siteName: string, websiteId?: string): GeneratedFile[] => {
  const pages: PageData[] = Array.isArray(content.pages) ? content.pages : [];

  if (pages.length === 0) {
    return [{ filename: 'index.html', html: buildPageHtml({ id: 'default', name: siteName, slug: '/', sections: [], navbar: content.navbar, footer: content.footer, globalStyles: content.globalStyles }, siteName, websiteId) }];
  }

  // Build set of all page slugs for inter-page link rewriting
  const pageSlugs = new Set<string>();
  for (const page of pages) {
    const slug = (page.slug || '/').replace(/^\/+/, '').replace(/\/+$/, '');
    if (slug && slug !== '/') pageSlugs.add(slug);
  }

  const files: GeneratedFile[] = pages.map((page) => {
    const slug = (page.slug || '/').replace(/^\/+/, '').replace(/\/+$/, '');
    const filename = slug === '' || slug === '/' ? 'index.html' : `${slug}/index.html`;
    return { filename, html: buildPageHtml(page, siteName, websiteId, undefined, pageSlugs) };
  });

  // Generate sitemap.xml
  const baseUrl = (process.env.PUBLISHED_SITES_BASE_URL || 'http://localhost:5000/sites') + '/' + (websiteId || 'site') + '/latest';
  const sitemapEntries = pages.map((page) => {
    const slug = (page.slug || '/').replace(/^\/+/, '').replace(/\/+$/, '');
    const loc = slug === '' || slug === '/' ? baseUrl + '/' : `${baseUrl}/${slug}/`;
    return `  <url><loc>${esc(loc)}</loc><lastmod>${new Date().toISOString().split('T')[0]}</lastmod></url>`;
  });
  files.push({
    filename: 'sitemap.xml',
    html: `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n${sitemapEntries.join('\n')}\n</urlset>`,
  });

  // Generate robots.txt
  files.push({
    filename: 'robots.txt',
    html: `User-agent: *\nAllow: /\nSitemap: ${baseUrl}/sitemap.xml\n`,
  });

  return files;
};
