        <p class="sub" style="color:${s?.paragraphColor || 'inherit'}">${richText(c.subheadline)}</p>
        <div class="btn-group">
          ${renderButton(c.ctaText, true, s)}
          ${renderButton(c.ctaSecondaryText, false, s)}
