  },

  htmlblock(c) {
    return `<div class="section-inner">${c.html || c.code || c.content || ''}</div>`;
  },

  content(c, s) {
    return `
      <div class="section-inner about-inner ${c.imagePosition === 'left' ? 'img-left' : ''}">
        <div class="about-text">
          ${c.headline ? `<h2 style="color:${s?.headingColor || 'inherit'}">${esc(c.headline)}</h2>` : ''}
