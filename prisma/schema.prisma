generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  password_hash           String?
  auth_provider           String                   @default("email")
  role                    UserRole                 @default(USER)
  institution_id          String?
  isActive                Boolean                  @default(true)
  isVerified              Boolean                  @default(false)
  lastLoginAt             DateTime?
  lastPasswordChangeAt    DateTime?
  created_at              DateTime                 @default(now())
  updated_at              DateTime                 @updatedAt
  deleted_at              DateTime?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  institution             Institution?             @relation(fields: [institution_id], references: [id])
  ownedWebsites           Website[]                @relation("WebsiteOwner")
  assets                  Asset[]

  @@index([email])
  @@index([auth_provider])
  @@index([deleted_at])
  @@map("users")
}

model Institution {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  status     String    @default("PENDING")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  users      User[]
  websites   Website[]
  templates  WebsiteTemplate[]
  sectionTemplates SectionTemplate[]
  assets     Asset[]

  @@map("institutions")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  token_hash String   @unique
  expiresAt  DateTime
  isUsed     Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token_hash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  token_hash String   @unique
  expiresAt  DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token_hash])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  token_hash String   @unique
  sessionId  String
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  replacedBy String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token_hash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Website {
  id                        String        @id @default(cuid())
  name                      String
  owner_id                  String
  source_template_id        String?
  status                    WebsiteStatus @default(DRAFT)
  thumbnail_url             String?
  currentDraftVersionId     String?
  currentPublishedVersionId String?
  published_url             String?
  created_at                DateTime      @default(now())
  updated_at                DateTime      @updatedAt
  deleted_at                DateTime?
  institution_id            String?
  content                   Json?
  settings_id               String?       @unique
  institution               Institution?  @relation(fields: [institution_id], references: [id])
  owner                     User          @relation("WebsiteOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  sourceTemplate            WebsiteTemplate? @relation(fields: [source_template_id], references: [id], onDelete: SetNull)
  settings                  Settings?     @relation(fields: [settings_id], references: [id], onDelete: Cascade)
  assets                    Asset[]
  versions                  WebsiteVersion[]
  deployments               Deployment[]
  domains                   Domain[]
  formSubmissions           FormSubmission[]
  contactSubmissions        ContactSubmission[]
  pageViews                 PageView[]

  @@index([owner_id])
  @@index([source_template_id])
  @@index([status])
  @@index([deleted_at])
  @@index([institution_id, status])
  @@index([owner_id, status])
  @@map("websites")
}

model Settings {
  id           String   @id @default(cuid())
  seo          Json?
  contact      Json?
  social_links Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  website      Website?

  @@map("settings")
}

enum UserRole {
  USER
  ADMIN
  STUDENT
  INSTRUCTOR
  INSTITUTION_ADMIN
  SUPER_ADMIN
}

enum WebsiteStatus {
  DRAFT
  PUBLISHED
  DELETED
}

enum TemplateScope {
  GLOBAL
  INSTITUTION
}

enum AssetScope {
  GLOBAL
  WEBSITE
}

enum AssetType {
  image
  video
  file
}

model Asset {
  id             String     @id @default(cuid())
  name           String
  type           AssetType  @default(image)
  url            String
  size           String?
  scope          AssetScope @default(GLOBAL)
  objectKey      String?
  owner_id       String
  institution_id String?
  website_id     String?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  owner       User         @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  institution Institution? @relation(fields: [institution_id], references: [id], onDelete: SetNull)
  website     Website?     @relation(fields: [website_id], references: [id], onDelete: Cascade)

  @@index([owner_id])
  @@index([website_id])
  @@index([scope])
  @@index([institution_id])
  @@map("assets")
}


model WebsiteTemplate {
  id            String    @id @default(cuid())
  name          String
  description   String
  category      String
  scope         TemplateScope @default(GLOBAL)
  institution_id String?
  image         String?
  global_styles Json      @default("{}")
  navbar        Json      @default("{}")
  footer        Json      @default("{}")
  home_layout   Json      @default("{}")
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  institution   Institution? @relation(fields: [institution_id], references: [id], onDelete: SetNull)
  websites      Website[]

  @@index([scope])
  @@index([institution_id])
}

model SectionTemplate {
  id             String         @id @default(cuid())
  name           String
  category       String
  scope          TemplateScope  @default(GLOBAL)
  institution_id String?
  props          Json           @default("{}")
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  institution    Institution?   @relation(fields: [institution_id], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([institution_id])
}

// ─── New Production Models ───────────────────────────────────────────

enum DeploymentStatus {
  PENDING
  BUILDING
  UPLOADING
  ACTIVE
  FAILED
  ROLLED_BACK
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

enum DomainStatus {
  PENDING
  ACTIVE
  ERROR
  DELETED
}

model WebsiteVersion {
  id          String   @id @default(cuid())
  website_id  String
  kind        String   // 'draft' | 'published'
  label       String
  snapshot    Json     // { pages, activePageId, templateId }
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  website     Website  @relation(fields: [website_id], references: [id], onDelete: Cascade)

  @@index([website_id])
  @@index([kind])
  @@map("website_versions")
}

model Deployment {
  id              String           @id @default(cuid())
  website_id      String
  version_id      String?
  status          DeploymentStatus @default(PENDING)
  url             String?
  domain          String
  artifact_prefix String?
  deployed_by     String
  error_message   String?
  file_count      Int              @default(0)
  total_size      BigInt           @default(0)
  ssl_enabled     Boolean          @default(false)
  logs            Json?            // string[]
  started_at      DateTime         @default(now())
  finished_at     DateTime?
  created_at      DateTime         @default(now())

  website         Website          @relation(fields: [website_id], references: [id], onDelete: Cascade)

  @@index([website_id])
  @@index([status])
  @@index([domain])
  @@index([created_at])
  @@index([website_id, status])
  @@map("deployments")
}

model Domain {
  id          String       @id @default(cuid())
  website_id  String
  domain      String       @unique
  type        DomainType   @default(SUBDOMAIN)
  status      DomainStatus @default(PENDING)
  ssl_enabled Boolean      @default(false)
  is_primary  Boolean      @default(false)
  dns_records Json?        // { A?, CNAME?, TXT?, verified? }
  acm_certificate_arn         String?
  cloudfront_distribution_id  String?
  cloudfront_domain_name      String?
  added_at    DateTime     @default(now())
  verified_at DateTime?
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  website     Website      @relation(fields: [website_id], references: [id], onDelete: Cascade)

  @@index([website_id])
  @@index([status])
  @@index([website_id, status])
  @@map("domains")
}

model FormSubmission {
  id          String   @id @default(cuid())
  website_id  String
  page_slug   String?
  form_name   String?
  data        Json     // the submitted form fields
  ip_address  String?
  user_agent  String?
  is_spam     Boolean  @default(false)
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  website     Website  @relation(fields: [website_id], references: [id], onDelete: Cascade)

  @@index([website_id])
  @@index([is_spam])
  @@index([is_read])
  @@index([created_at])
  @@map("form_submissions")
}

model AuditLog {
  id          String   @id @default(cuid())
  user_id     String?
  action      String   // 'website.publish', 'website.delete', 'user.role_change', etc.
  entity_type String   // 'website', 'user', 'domain', etc.
  entity_id   String?
  metadata    Json?    // extra context about the action
  ip_address  String?
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([action])
  @@index([entity_type, entity_id])
  @@index([created_at])
  @@map("audit_logs")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  websiteId String
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("unread") // unread, read, replied
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([status])
  @@index([createdAt])
}

model PageView {
  id         String   @id @default(cuid())
  website_id String
  path       String   @default("/")
  referrer   String?
  user_agent String?
  country    String?
  created_at DateTime @default(now())

  website    Website  @relation(fields: [website_id], references: [id], onDelete: Cascade)

  @@index([website_id])
  @@index([created_at])
  @@index([website_id, created_at])
  @@map("page_views")
}