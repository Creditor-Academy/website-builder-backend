# ─── Required ─────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
POSTGRESQL_URL=postgresql://user:password@localhost:5432/buildora

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
REDIS_URL=https://your-upstash-url.upstash.io
REDIS_TOKEN=your-upstash-token

# ─── S3 (Assets bucket) ──────────────────────────────────────────────────────
S3_BUCKET=buildora-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/buildora-assets

# ─── S3 (Published sites bucket) ─────────────────────────────────────────────
S3_SITES_BUCKET=your-sites-bucket
PUBLISHED_SITES_BASE_URL=http://localhost:5000/sites

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Buildora <noreply@yourdomain.com>

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── API & Publishing ────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:5000/api/v1
PUBLIC_SITE_HOST=buildora.app
SERVER_IP=your.server.ip.address

# ─── Optional ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug
APP_NAME=Buildora
BCRYPT_SALT_ROUNDS=12
FRONTEND_ORIGINS=http://localhost:8080,http://localhost:8081
FRONTEND_URL=http://localhost:8080